# ── Strava API credentials (used by server.js for local dev) ────────────────
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_REFRESH_TOKEN=your_refresh_token
STRAVA_CLUB_ID=your_club_id

# ── Firebase / CI (never commit real values — set as GitLab CI variables) ────
# FIREBASE_TOKEN=        # obtain with: firebase login:ci
# FIREBASE_PROJECT_ID=   # your Firebase project ID (also set in .firebaserc)
#
# The four STRAVA_* variables above must also be set as GitLab CI variables
# so the pipeline can push them to Firebase with:
#   firebase functions:config:set strava.client_id="$STRAVA_CLIENT_ID" ...
