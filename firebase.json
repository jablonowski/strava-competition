{
  "hosting": {
    "public": "frontend/dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "**",      "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/current",
        "headers": [
          { "key": "X-Frame-Options",        "value": "ALLOWALL" },
          { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
        ]
      }
    ]
  },
  "functions": {
    "source":  "functions",
    "runtime": "nodejs22"
  }
}
